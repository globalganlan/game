# ========================================
# 英雄模型自動生成 — 環境變數設定
# ========================================
# 複製此檔案為 hero-gen.env 並填入你的 API 金鑰
# cp hero-gen.env.example hero-gen.env

# --- Meshy.ai API ---
# 註冊：https://app.meshy.ai/  （免費方案 200 credits/月）
# API Key：Settings → API Keys → Create
MESHY_API_KEY=your_meshy_api_key_here

# --- Mixamo (Adobe) ---
# 1. 登入 https://www.mixamo.com/
# 2. 開啟 DevTools (F12) → Network 分頁
# 3. 隨意操作一次，找到任何 www.mixamo.com/api 請求
# 4. 從 Request Headers 中複製以下兩個值：
#    - Authorization: Bearer <TOKEN>
#    - x-csrf-token: <CSRF>
MIXAMO_TOKEN=your_adobe_bearer_token_here
MIXAMO_CSRF=your_csrf_token_here

# --- Blender 路徑（可選，腳本會自動偵測）---
# BLENDER_PATH=D:\Blender\blender.exe
